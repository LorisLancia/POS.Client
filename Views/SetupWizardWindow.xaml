<Window x:Class="POS.Client.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POS Setup Wizard" 
        Height="620" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#f5f5f5">
        <Border Background="White" CornerRadius="12" Padding="30" Margin="20"
                BorderBrush="#ddd" BorderThickness="1">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="POS Setup Wizard" FontSize="24" FontWeight="Bold" 
                           Margin="0,0,0,5" Foreground="#333"/>
                <TextBlock x:Name="txtStepDescription" Text="Step 1 of 3: Connect to Server" 
                           FontSize="14" Foreground="#666" Margin="0,0,0,20"/>

                <!-- === STEP 1: Server URL === -->
                <StackPanel x:Name="panelStep1" Visibility="Visible">
                    <TextBlock Text="Server URL *" FontWeight="SemiBold" Margin="0,5"/>
                    <TextBox x:Name="txtServerUrl" Padding="8" FontSize="14"
                             BorderBrush="#ccc" BorderThickness="1" Margin="0,0,0,10"
                             Text="http://localhost:3000"/>
                    <TextBlock Text="Example: http://192.168.1.100:3000" 
                               FontSize="11" Foreground="#888" Margin="0,0,0,15"/>

                    <Button x:Name="btnConnect" Content="Connect" Padding="15,8" 
                            FontSize="14" FontWeight="Bold" Background="#007bff" 
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="btnConnect_Click" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- === STEP 2: Admin Login === -->
                <StackPanel x:Name="panelStep2" Visibility="Collapsed">
                    <TextBlock Text="Admin Username *" FontWeight="SemiBold" Margin="0,5"/>
                    <TextBox x:Name="txtAdminUser" Padding="8" FontSize="14"
                             BorderBrush="#ccc" BorderThickness="1" Margin="0,0,0,10"/>

                    <TextBlock Text="Admin PIN *" FontWeight="SemiBold" Margin="0,5"/>
                    <PasswordBox x:Name="txtAdminPin" Padding="8" FontSize="14"
                                 BorderBrush="#ccc" BorderThickness="1" Margin="0,0,0,10"/>

                    <TextBlock Text="Login as administrator to configure this POS register." 
                               FontSize="11" Foreground="#888" Margin="0,0,0,15" TextWrapping="Wrap"/>

                    <Button x:Name="btnAdminLogin" Content="Login as Admin" Padding="15,8" 
                            FontSize="14" FontWeight="Bold" Background="#28a745" 
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="btnAdminLogin_Click" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- === STEP 3: POS Configuration === -->
                <StackPanel x:Name="panelStep3" Visibility="Collapsed">
                    <TextBlock Text="Company *" FontWeight="SemiBold" Margin="0,5"/>
                    <ComboBox x:Name="cmbCompany" Padding="8" FontSize="14"
                              BorderBrush="#ccc" BorderThickness="1" Margin="0,0,0,10"
                              SelectionChanged="cmbCompany_SelectionChanged"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>

                    <TextBlock Text="Warehouse *" FontWeight="SemiBold" Margin="0,5"/>
                    <ComboBox x:Name="cmbWarehouse" Padding="8" FontSize="14"
                              BorderBrush="#ccc" BorderThickness="1" Margin="0,0,0,10"
                              IsEnabled="False"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>

                    <TextBlock Text="Register Name *" FontWeight="SemiBold" Margin="0,5"/>
                    <TextBox x:Name="txtRegisterName" Padding="8" FontSize="14"
                             BorderBrush="#ccc" BorderThickness="1" Margin="0,0,0,10"
                             Text="Main Register"/>

                    <TextBlock Text="Location" FontWeight="SemiBold" Margin="0,5"/>
                    <TextBox x:Name="txtLocation" Padding="8" FontSize="14"
                             BorderBrush="#ccc" BorderThickness="1" Margin="0,0,0,10"
                             Text="Main Counter"/>

                    <TextBlock Text="Hardware ID" FontWeight="SemiBold" Margin="0,5"/>
                    <TextBox x:Name="txtHardwareId" Padding="8" FontSize="12" IsReadOnly="True"
                             Background="#f0f0f0" BorderBrush="#ccc" BorderThickness="1" 
                             Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnBack" Content="Back" Padding="15,8" 
                                FontSize="14" FontWeight="Bold" Background="#6c757d" 
                                Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="btnBack_Click" Margin="0,0,10,0"/>
                        <Button x:Name="btnFinish" Content="Complete Setup" Padding="20,10" 
                                FontSize="14" FontWeight="Bold" Background="#007bff" 
                                Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="btnFinish_Click"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>